# =============================================================
# Seguridad — Directorio de uploads
# =============================================================

# Deshabilitar listado de directorios
Options -Indexes

# Bloquear ejecución de PHP en uploads
<FilesMatch "\.php$">
    Deny from all
</FilesMatch>

# Permitir solo tipos de imagen
<FilesMatch "\.(jpg|jpeg|png|gif|webp)$">
    Order Allow,Deny
    Allow from all
</FilesMatch>

# Cache de imágenes: 7 días
<FilesMatch "\.(jpg|jpeg|png|gif|webp)$">
    Header set Cache-Control "public, max-age=604800, immutable"
</FilesMatch>
